---
const pathname = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Products', href: '/products' },
];
---
<header class="sticky top-0 z-50 bg-[#0a0a0a]/80 backdrop-blur-xl border-b border-zinc-800/50">
  <nav class="max-w-5xl mx-auto px-5 h-14 flex items-center justify-between">
    <a href="/" class="font-bold text-white tracking-tight">HstarOrg</a>
    <div class="flex items-center gap-6 text-sm">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'transition-colors',
            (item.href === '/' ? pathname === '/' : pathname.startsWith(item.href))
              ? 'text-white'
              : 'text-zinc-500 hover:text-zinc-200',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://github.com/hstarorg"
        target="_blank"
        rel="noopener noreferrer"
        class="text-zinc-500 hover:text-zinc-200 transition-colors"
      >
        GitHub
      </a>
    </div>
  </nav>
</header>
