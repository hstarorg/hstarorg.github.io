---
---
<section class="relative overflow-hidden">
  <!-- Aurora 背景 -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="aurora-blob absolute -top-32 left-1/4 w-[500px] h-[400px] rounded-full bg-blue-600/8 blur-[100px]"></div>
    <div class="aurora-blob-delay absolute -top-20 right-1/4 w-[400px] h-[350px] rounded-full bg-violet-600/8 blur-[100px]"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-5 pt-32 pb-20">
    <h1 class="text-5xl sm:text-6xl font-extrabold text-white leading-[1.1] tracking-tight mb-5">
      HstarOrg
    </h1>
    <p class="text-zinc-400 text-lg max-w-md leading-relaxed mb-10">
      开源项目集合，覆盖 Web3、应用服务与开发者工具。
    </p>
    <div class="flex gap-3">
      <a
        href="/products"
        class="group px-5 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium transition-all hover:shadow-[0_0_24px_-4px_rgba(59,130,246,0.5)]"
      >
        浏览全部
      </a>
      <a
        href="https://github.com/hstarorg"
        target="_blank"
        rel="noopener noreferrer"
        class="px-5 py-2.5 rounded-lg border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-600 text-sm transition-all"
      >
        GitHub
      </a>
    </div>
  </div>
</section>
