---
---
<section class="relative overflow-hidden">
  <!-- Aurora 背景 -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="aurora-blob absolute -top-32 left-1/4 w-[600px] h-[500px] rounded-full bg-blue-600/10 blur-[120px]"></div>
    <div class="aurora-blob-delay absolute -top-20 right-1/4 w-[500px] h-[400px] rounded-full bg-violet-600/10 blur-[120px]"></div>
    <div class="aurora-blob absolute top-40 left-1/2 w-[300px] h-[300px] rounded-full bg-pink-600/5 blur-[100px]"></div>
  </div>

  <!-- 浮动装饰 -->
  <div class="absolute top-24 right-[15%] w-3 h-3 rounded-full border border-blue-500/30 animate-float hidden sm:block"></div>
  <div class="absolute top-44 right-[25%] w-2 h-2 rounded-full bg-violet-500/40 animate-float-delay hidden sm:block"></div>
  <div class="absolute top-32 left-[10%] w-2 h-2 rounded-full border border-violet-500/20 animate-float-delay hidden sm:block"></div>

  <div class="relative max-w-5xl mx-auto px-5 pt-32 pb-20">
    <p class="text-sm text-zinc-500 mb-5 cursor-blink">Hello world</p>
    <h1 class="text-5xl sm:text-7xl font-extrabold leading-[1.05] tracking-tight mb-6">
      <span class="text-white">I'm </span>
      <span class="text-gradient-animated">Jay Hu</span>
    </h1>
    <p class="text-zinc-400 text-xl max-w-lg leading-relaxed mb-3">
      Full-Stack & Web3 Developer
    </p>
    <p class="text-zinc-600 text-base max-w-lg leading-relaxed mb-10">
      后端起步，全栈进化，现深耕 Web3。<br />
      13 年从 .NET 到智能合约，喜欢造工具、写开源。
    </p>

    <!-- 技术标签 -->
    <div class="flex flex-wrap gap-2 mb-10">
      {['TypeScript', 'React', 'Node.js', 'Go', 'Solidity', 'Cairo'].map((t) => (
        <span class="tech-pill text-xs text-zinc-400 border border-zinc-800 rounded-full px-3 py-1">
          {t}
        </span>
      ))}
    </div>

    <div class="flex items-center gap-5">
      <a
        href="https://github.com/hstarorg"
        target="_blank"
        rel="noopener noreferrer"
        class="text-zinc-500 hover:text-white transition-colors hover:drop-shadow-[0_0_8px_rgba(59,130,246,0.5)]"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 16 16" class="w-5 h-5 fill-current"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
      <a
        href="mailto:hm910705@163.com"
        class="text-zinc-500 hover:text-white transition-colors hover:drop-shadow-[0_0_8px_rgba(139,92,246,0.5)]"
        aria-label="Email"
      >
        <svg viewBox="0 0 20 20" class="w-5 h-5 fill-current"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
      </a>
    </div>
  </div>
</section>
