---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import CategorySection from '../components/CategorySection.astro';

const allProducts = (await getCollection('products')).sort(
  (a, b) => a.data.order - b.data.order,
);

const categories = [
  { id: 'web3', title: 'Web3 & Blockchain', description: '智能合约、链上工具与去中心化应用', key: 'web3' as const },
  { id: 'apps', title: '应用与服务', description: '面向用户的产品与在线服务', key: 'app' as const },
  { id: 'devtools', title: '开发者工具', description: '提升效率的库、框架与工具', key: 'devtool' as const },
];
---
<Base title="Products - HstarOrg">
  <div class="max-w-5xl mx-auto px-5 pt-20 pb-28">
    <h1 class="text-3xl font-extrabold text-white tracking-tight mb-1">全部项目</h1>
    <p class="text-sm text-zinc-500 mb-14">{allProducts.length} 个开源项目</p>

    <div class="space-y-16">
      {categories.map((cat) => {
        const products = allProducts
          .filter((p) => p.data.category === cat.key)
          .map((p) => p.data);
        return (
          <CategorySection
            id={cat.id}
            title={`${cat.title} (${products.length})`}
            description={cat.description}
            products={products}
          />
        );
      })}
    </div>
  </div>
</Base>
