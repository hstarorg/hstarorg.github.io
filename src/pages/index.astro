---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';

const allProducts = (await getCollection('products')).sort(
  (a, b) => a.data.order - b.data.order,
);
const featured = allProducts.filter((p) => p.data.featured).map((p) => p.data);
---
<Base>
  <Hero />

  <div class="max-w-5xl mx-auto px-5 pb-28 space-y-20">
    <section>
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-lg font-bold text-white">推荐项目</h2>
        <a href="/products" class="text-sm text-zinc-500 hover:text-blue-400 transition-colors">
          全部 &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {featured.map((product) => (
          <ProductCard
            title={product.title}
            description={product.description}
            image={product.image}
            demoUrl={product.demoUrl}
            repoUrl={product.repoUrl}
            tags={product.tags}
          />
        ))}
      </div>
    </section>
  </div>
</Base>
